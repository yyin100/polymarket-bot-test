{
  "name": "polymarket-btc-updown-bot",
  "version": "1.0.0",
  "description": "Dual-sided complementary-token arb bot on Polymarket BTC Up/Down 5-min markets",
  "type": "module",
  "scripts": {
    "start":    "node src/index.js",
    "dev":      "node --watch src/index.js",
    "arb":      "cross-env TRADING_MODE=arb  node src/index.js",
    "copy":     "cross-env TRADING_MODE=copy node src/index.js",
    "arb:dev":  "cross-env TRADING_MODE=arb  node --watch src/index.js",
    "copy:dev": "cross-env TRADING_MODE=copy node --watch src/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.8.1",
    "@polymarket/order-utils": "^3.0.1",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "winston": "^3.13.0",
    "ioredis-om": "^5.10.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
